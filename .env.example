# ================= DocFlow AI - Local Configuration =================
# Everything here points at localhost / local files. No cloud API keys needed.

# --- Storage ---
DATABASE_URL=sqlite:///./docflow.db
UPLOAD_DIR=./uploads
CHROMA_DIR=./chroma_db

# --- OCR ---
TESSERACT_CMD=tesseract          # path to local tesseract binary
TIKA_SERVER_JAR=                 # leave blank to let tika-python auto-download/run local jar

# --- Local LLM (Ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text   # optional, we default to sentence-transformers instead

# --- Local embeddings model (downloaded once, runs on-device) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
